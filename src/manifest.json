{
  "manifest_version": 2,
  "name": "Quick Move",
  "description": "__MSG_extensionDescription__",
  "version": "1.110.0",
  "default_locale": "en",
  "author": "MeiNic (fork), original author: Philipp Kewisch",
  "homepage_url": "https://github.com/MeiNic/quick-move#readme",
  "browser_specific_settings": {
    "gecko": {
      "id": "qfm-classic@meinic.github.io",
      "strict_min_version": "140.0"
    }
  },
  "icons": {
    "32": "icon.png"
  },
  "options_ui": {
    "page": "options/options.html",
    "browser_style": true
  },
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "commands": {
    "open-quick-move": {
      "suggested_key": {
        "default": "Ctrl+Shift+1",
        "mac": "Command+Shift+1"
      },
      "description": "Quick Move: Move messages"
    },
    "open-quick-move-secondary": {
      "suggested_key": {
        "default": "Ctrl+Shift+2",
        "mac": "Command+Shift+2"
      },
      "description": "Quick Move: Copy messages"
    },
    "open-quick-move-tertiary": {
      "suggested_key": {
        "default": "Ctrl+Shift+3",
        "mac": "Command+Shift+3"
      },
      "description": "Quick Move: Go to folder"
    }
  },
  "permissions": [
    "storage",
    "accountsRead",
    "messagesRead",
    "messagesMove",
    "tabs"
  ]
}
