{
  "name": "quick-move",
  "description": "Quick Move",
  "version": "1.110.0",
  "private": true,
  "author": "MeiNic <nico.meissner2006@gmail.com>",
  "license": "MPL-2.0",
  "homepage": "https://github.com/MeiNic/quick-move#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/MeiNic/quick-move.git"
  },
  "bugs": {
    "url": "https://github.com/MeiNic/quick-move/issues"
  },
  "scripts": {
    "build": "rm dist/quickmove.xpi; (cd src && zip -9r ../dist/quickmove.xpi *)",
    "clean": "rm dist/quickmove.xpi",
    "bump": "node -e \"const fs=require('fs');const v=process.argv[1];if(!v){console.error('Usage: npm run bump -- <version>');process.exit(1);}for(const f of ['package.json','src/manifest.json']){const j=JSON.parse(fs.readFileSync(f,'utf8'));j.version=v;fs.writeFileSync(f,JSON.stringify(j,null,2)+'\\n');}\"",
    "tag": "git tag v$(jq -r '.version' src/manifest.json)",
    "lint0": ".\\node_modules\\.bin\\eslint src",
    "lint": "commitlint -f origin/master && eslint src || true"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@babel/eslint-parser": "^7.25.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-fetch-options": "^0.0.5",
    "eslint-plugin-html": "^8.0.0",
    "eslint-plugin-mozilla": "^4.0.0",
    "eslint-plugin-no-unsanitized": "^4.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "prettier": "^3.2.0"
  }
}
